{
  "version": "0.1.0",
  "source": "docs/task/drafts/2/draft.txt",
  "scope": "editor-shell + left navigation + layers tree + right sidebar(page styles/export)",
  "layoutModel": {
    "root": "fullscreen-root",
    "regions": [
      {
        "id": "canvasViewport",
        "role": "main-canvas",
        "signals": [
          "canvas",
          "comments overlay",
          "multiplayer cursor overlay"
        ]
      },
      {
        "id": "leftSidebar",
        "role": "navigation + pages + layer-tree",
        "sections": [
          "navigation bar",
          "file header",
          "pages panel",
          "objects/layers panel"
        ]
      },
      {
        "id": "rightSidebar",
        "role": "properties/page panel",
        "sections": [
          "header controls",
          "tab header(draw)",
          "page background",
          "styles",
          "export"
        ]
      }
    ]
  },
  "entities": {
    "shell": {
      "fields": {
        "zoomPercent": "number",
        "activeTab": "draw",
        "panelWidths": {
          "left": "number",
          "right": "number"
        }
      }
    },
    "page": {
      "fields": {
        "id": "string",
        "name": "string",
        "background": {
          "visible": "boolean",
          "colorHex": "string"
        },
        "styles": "styleCollection",
        "exportSettings": "exportSetting[]"
      }
    },
    "layerTree": {
      "fields": {
        "nodes": "layerNode[]",
        "expandedIds": "string[]",
        "selectedIds": "string[]"
      }
    },
    "layerNode": {
      "fields": {
        "id": "string",
        "name": "string",
        "type": "enum(frame|group|path|rect|ellipse|polygon|star|text|image|section|unknown)",
        "depth": "number",
        "visible": "boolean",
        "locked": "boolean",
        "isMask": "boolean"
      }
    }
  },
  "commandGroups": [
    {
      "group": "shell",
      "commands": [
        "shell.openMainMenu",
        "shell.switchLeftTab(file|assets|find|variables)",
        "shell.toggleUIChrome",
        "shell.resizeLeftPanel",
        "shell.resizeRightPanel",
        "shell.setZoom"
      ]
    },
    {
      "group": "pages",
      "commands": [
        "page.add",
        "page.rename",
        "page.select"
      ]
    },
    {
      "group": "layers",
      "commands": [
        "layer.expand",
        "layer.collapseAll",
        "layer.select",
        "layer.panToNode",
        "layer.reorder"
      ]
    },
    {
      "group": "pageStyles",
      "commands": [
        "page.applyVariableMode",
        "page.setBackgroundPaint",
        "style.create",
        "export.addSetting"
      ]
    }
  ],
  "notes": [
    "This snapshot is page-focused (right panel shows Page/Styles/Export) instead of shape-focused property controls.",
    "Layers panel is virtualized and row-driven; tree behavior should remain runtime-backed, not React-local source of truth.",
    "Shell-level resize and panel state are explicit interaction surfaces worth stabilizing in app-state contracts."
  ]
}
