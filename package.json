{
  "name": "venus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Composable canvas runtime monorepo for multi-editor products",
  "scripts": {
    "init:workspace": "pnpm install && pnpm governance:check && pnpm governance:file-shape && pnpm typecheck",
    "dev": "pnpm --filter @venus/vector-editor-web dev",
    "build": "pnpm --filter @venus/vector-editor-web build",
    "dev vector": "pnpm --filter @venus/vector-editor-web dev",
    "dev playground": "pnpm --filter @venus/playground dev",
    "lint": "eslint . && node ./scripts/module-governance-check.mjs",
    "governance:check": "node ./scripts/module-governance-check.mjs",
    "governance:cutover-freeze": "node ./scripts/cutover-freeze-guard.mjs",
    "governance:cutover-parity": "node ./scripts/cutover-parity-gate.mjs",
    "governance:cutover-archive": "node ./scripts/cutover-archive-finalize.mjs",
    "governance:cutover-rename": "node ./scripts/cutover-rename-preflight.mjs",
    "governance:cutover-impact": "node ./scripts/cutover-rename-impact-report.mjs",
    "governance:cutover-rewrite": "node ./scripts/cutover-reference-rewrite.mjs",
    "governance:file-shape": "node ./scripts/file-shape-guard.mjs --changed",
    "governance:file-shape:all": "node ./scripts/file-shape-guard.mjs",
    "governance:test": "node --test ./scripts/module-governance-check.test.mjs",
    "engine:cr:check": "pnpm --filter @venus/engine cr:check",
    "engine:bench:baseline": "pnpm --filter @venus/engine bench:baseline",
    "engine:dashboard:update": "pnpm --filter @venus/engine dashboard:update",
    "engine:policy:replay": "pnpm --filter @venus/engine policy:replay",
    "engine:debug:guard": "pnpm --filter @venus/engine debug:guard",
    "ai:fast-loop": "pnpm --filter @venus/engine exec tsc --noEmit && pnpm governance:file-shape -- --changed --scope engine && pnpm --filter @venus/engine test",
    "ai:release-loop": "pnpm typecheck && pnpm lint && pnpm test && pnpm governance:file-shape && pnpm governance:check",
    "typecheck": "tsc -b tsconfig.json",
    "perf:gate": "pnpm --filter @venus/vector-editor-web perf:gate",
    "test": "pnpm -r --if-present test",
    "gh:pr": "gh pr create --fill",
    "cpr": "sh -c 'msg=\"$1\"; if [ -z \"$msg\" ] || [ \"$msg\" = \"--\" ]; then echo \"Usage: pnpm gh:cpr -- \\\"commit message\\\"\"; exit 1; fi; git add -A && git commit -m \"$msg\" && git push && gh pr create --fill' --"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "flatbuffers": "^25.9.23",
    "rbush-3d": "^0.0.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.2",
      "rolldown": "1.0.0-rc.11",
      "@rolldown/pluginutils": "1.0.0-rc.11"
    }
  },
  "packageManager": "pnpm@8.7.4",
  "devDependencies": {
    "@types/node": "^25.9.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
