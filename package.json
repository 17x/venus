{
  "name": "venus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Composable canvas runtime monorepo for multi-editor products",
  "scripts": {
    "init:workspace": "pnpm install && pnpm governance:check && pnpm governance:file-shape && pnpm governance:machine-check && pnpm build:rules && pnpm typecheck",
    "dev": "pnpm --filter @venus/vector-editor-web dev",
    "build": "pnpm --filter @venus/vector-editor-web build",
    "dev:vector": "pnpm --filter @venus/vector-editor-web dev",
    "dev:playground": "pnpm --filter @venus/playground dev",
    "lint": "eslint . && node ./scripts/module-governance-check/module-governance-check.mjs",
    "governance:check": "node ./scripts/module-governance-check/module-governance-check.mjs",
    "governance:file-shape": "node ./scripts/file-shape-guard/file-shape-guard.mjs --changed",
    "governance:file-shape:all": "node ./scripts/file-shape-guard/file-shape-guard.mjs",
    "governance:machine-check": "node ./scripts/governance-machine-check/governance-machine-check.mjs",
    "governance:entropy-report": "node ./scripts/entropy-report/entropy-report.mjs",
    "governance:test": "node --test ./scripts/module-governance-check/module-governance-check.test.mjs",
    "build:rules": "node ./scripts/build-rules/build-rules.mjs",
    "build:repo": "pnpm build && pnpm typecheck && pnpm lint && pnpm test && pnpm governance:file-shape:all && pnpm governance:check && pnpm governance:machine-check && pnpm build:rules && pnpm governance:entropy-report",
    "engine:cr:check": "pnpm --filter @venus/engine cr:check",
    "engine:bench:baseline": "pnpm --filter @venus/engine bench:baseline",
    "engine:dashboard:update": "pnpm --filter @venus/engine dashboard:update",
    "engine:policy:replay": "pnpm --filter @venus/engine policy:replay",
    "engine:debug:guard": "pnpm --filter @venus/engine debug:guard",
    "ai:fast-loop": "pnpm --filter @venus/engine exec tsc --noEmit && pnpm governance:file-shape -- --changed --scope engine && pnpm --filter @venus/engine test",
    "ai:release-loop": "pnpm typecheck && pnpm lint && pnpm test && pnpm governance:file-shape && pnpm governance:check && pnpm governance:machine-check && pnpm build:rules && pnpm governance:entropy-report",
    "typecheck": "tsc -b tsconfig.json",
    "perf:gate": "pnpm --filter @venus/vector-editor-web perf:gate",
    "test": "pnpm -r --if-present test",
    "gh:pr": "gh pr create --fill"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "flatbuffers": "^25.9.23",
    "rbush-3d": "^0.0.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.2",
      "rolldown": "1.0.0-rc.11",
      "@rolldown/pluginutils": "1.0.0-rc.11"
    }
  },
  "packageManager": "pnpm@8.7.4",
  "devDependencies": {
    "@types/node": "^25.9.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
