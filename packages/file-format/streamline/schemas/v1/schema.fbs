include "../../../base/schemas/v1/schema.fbs";

namespace Venus.Streamline;

// App-specific extensions should be additive and versioned here.
table StreamlineMetadata {
  board_id: string;
  lane_mode: bool = false;
}

table StreamlineSnapshot {
  version: uint32;
  core: Venus.Core.DocumentSnapshot;
  metadata: StreamlineMetadata;
}

root_type StreamlineSnapshot;
