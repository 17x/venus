{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@venus/lib": ["packages/lib/src/index.ts"],
      "@venus/editor-primitive": ["packages/editor-primitive/src/index.ts"],
      "@venus/editor-primitive/*": ["packages/editor-primitive/src/*/index.ts"],
      "@venus/engine": ["packages/engine/src/index.ts"]
    }
  },
  "references": [
    { "path": "../../packages/lib/tsconfig.json" },
    { "path": "../../packages/editor-primitive/tsconfig.json" },
    { "path": "../../packages/engine/tsconfig.json" }
  ],
  "include": [
    "scripts/render-parity-runtime-auto-report.ts",
    "scripts/render-parity-runtime-replay-batch-frame-stage-counters.ts",
    "scripts/render-parity-runtime-replay-batch-resource-counters.ts",
    "scripts/render-parity-runtime-replay-batch.ts",
    "scripts/render-parity-runtime-replay-history-gate.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
