{
  "name": "@venus/vector-editor-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm vite",
    "typecheck": "pnpm exec tsc -b ./tsconfig.app.json ./tsconfig.node.json",
    "build": "vite build --configLoader runner",
    "pnpm build": "pnpm run build",
    "lint": "eslint . && node ./scripts/ui-style-guard.mjs && node ./scripts/runtime-governance-check.mjs && node ../../scripts/module-governance-check/module-governance-check.mjs --scope vector",
    "regression:boolean-contour": "pnpm dlx tsx --tsconfig ./tsconfig.app.json ./scripts/boolean-contour-regression.ts",
    "regression:m1-core": "node ./scripts/m1-core-regression.mjs",
    "m2:run-all": "node ./scripts/m2-run-all.mjs",
    "perf:baseline": "node ./scripts/perf-baseline.mjs --report ./scripts/perf-gate.report.template.json --output ./docs/product-requirements/m1-performance-baseline.json",
    "perf:baseline:check": "node ./scripts/perf-gate.mjs --report ./docs/product-requirements/m1-performance-baseline.json --config ./scripts/perf-gate.config.json",
    "perf:gate": "node ./scripts/perf-gate.mjs",
    "perf:gate:template": "node ./scripts/perf-gate.mjs --report ./scripts/perf-gate.report.template.json",
    "perf:fps:playwright": "node ./scripts/playwright-fps-check.mjs",
    "report:feature-matrix": "pnpm dlx tsx ./scripts/template-feature-matrix-report.ts",
    "report:render-parity-checklist": "pnpm dlx tsx ./scripts/render-parity-checklist-report.ts",
    "report:render-parity-sampled": "pnpm dlx tsx ./scripts/render-parity-sampled-report.ts",
    "report:render-parity-sample-from-runtime": "pnpm dlx tsx ./scripts/render-parity-sample-from-runtime-diagnostics.ts",
    "report:render-parity-runtime-auto": "pnpm dlx tsx ./scripts/render-parity-runtime-auto-report.ts",
    "report:render-parity-runtime-replay": "pnpm dlx tsx ./scripts/render-parity-runtime-auto-report.ts --input ./scripts/runtime-diagnostics-sample-export.json --replay-baseline",
    "report:render-parity-runtime-replay-batch": "pnpm dlx tsx ./scripts/render-parity-runtime-replay-batch.ts --input-dir ./scripts/runtime-diagnostics-replay-inputs --dashboard-output ./docs/product-requirements/render-parity-reports/runtime-replay.batch.dashboard.json",
    "report:render-parity-runtime-replay-history-gate": "pnpm dlx tsx ./scripts/render-parity-runtime-replay-history-gate.ts --dashboard ./docs/product-requirements/render-parity-reports/runtime-replay.batch.dashboard.json --history-file ./docs/product-requirements/render-parity-reports/runtime-replay.batch.history.json --gate-output ./docs/product-requirements/render-parity-reports/runtime-replay.batch.gate.json",
    "report:render-parity-runtime-replay-history-gate:strict": "pnpm dlx tsx ./scripts/render-parity-runtime-replay-history-gate.ts --dashboard ./docs/product-requirements/render-parity-reports/runtime-replay.batch.dashboard.json --history-file ./docs/product-requirements/render-parity-reports/runtime-replay.batch.history.json --gate-output ./docs/product-requirements/render-parity-reports/runtime-replay.batch.gate.json --max-rolling-regressed 0 --max-rolling-mixed 0 --max-rolling-unknown 0 --fail-on-status",
    "report:render-parity-runtime-replay-history-gate:strict:stage": "rm -f ./docs/product-requirements/render-parity-reports/runtime-replay.stage.batch.history.json ./docs/product-requirements/render-parity-reports/runtime-replay.stage.batch.gate.json && pnpm dlx tsx ./scripts/render-parity-runtime-replay-history-gate.ts --dashboard ./docs/product-requirements/render-parity-reports/runtime-replay.batch.dashboard.json --history-file ./docs/product-requirements/render-parity-reports/runtime-replay.stage.batch.history.json --gate-output ./docs/product-requirements/render-parity-reports/runtime-replay.stage.batch.gate.json --max-rolling-regressed 0 --max-rolling-mixed 0 --max-rolling-unknown 0 --max-stage-scheduler-unknown 0 --max-stage-scene-apply-unknown 0 --max-rolling-stage-scheduler-unknown 0 --max-rolling-stage-scene-apply-unknown 0 --max-stage-scheduler-unknown-rate-percent 0 --max-stage-scene-apply-unknown-rate-percent 0 --max-rolling-stage-scheduler-unknown-rate-percent 0 --max-rolling-stage-scene-apply-unknown-rate-percent 0 --fail-on-status",
    "report:render-parity-runtime-replay-history-gate:strict:resource-rate": "rm -f ./docs/product-requirements/render-parity-reports/runtime-replay.resource-rate.batch.history.json ./docs/product-requirements/render-parity-reports/runtime-replay.resource-rate.batch.gate.json && pnpm dlx tsx ./scripts/render-parity-runtime-replay-history-gate.ts --dashboard ./docs/product-requirements/render-parity-reports/runtime-replay.batch.dashboard.json --history-file ./docs/product-requirements/render-parity-reports/runtime-replay.resource-rate.batch.history.json --gate-output ./docs/product-requirements/render-parity-reports/runtime-replay.resource-rate.batch.gate.json --max-rolling-regressed 0 --max-rolling-mixed 0 --max-rolling-unknown 0 --max-resource-decode-unknown-rate-percent 0 --max-resource-compression-unknown-rate-percent 0 --max-rolling-resource-decode-unknown-rate-percent 0 --max-rolling-resource-compression-unknown-rate-percent 0 --fail-on-status",
    "report:render-parity-runtime-replay-batch-gate": "pnpm run report:render-parity-runtime-replay-batch && pnpm run report:render-parity-runtime-replay-history-gate",
    "report:render-parity-runtime-replay-batch-gate:strict": "pnpm run report:render-parity-runtime-replay-batch && pnpm run report:render-parity-runtime-replay-history-gate:strict",
    "report:render-parity-runtime-replay-batch-gate:strict:stage": "pnpm run report:render-parity-runtime-replay-batch && pnpm run report:render-parity-runtime-replay-history-gate:strict:stage",
    "report:render-parity-runtime-replay-batch-gate:strict:resource-rate": "pnpm run report:render-parity-runtime-replay-batch && pnpm run report:render-parity-runtime-replay-history-gate:strict:resource-rate",
    "report:render-parity-summary-diff": "pnpm dlx tsx ./scripts/render-parity-summary-diff-report.ts",
    "report:render-parity-summary-trend": "pnpm dlx tsx ./scripts/render-parity-summary-trend-report.ts",
    "test:product-specs": "node --test ./src/testing/product-specs/**/*.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "4.2.2",
    "@venus/editor-primitive": "workspace:*",
    "@venus/engine": "workspace:*",
    "@venus/lib": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "polygon-clipping": "^0.15.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.5.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.55.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "8.0.2",
    "vite-bundle-analyzer": "^1.3.7"
  }
}
