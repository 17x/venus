{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@venus/document-core": ["apps/vector-editor-web/src/model/index.ts"],
      "@venus/lib": ["packages/lib/src/index.ts"],
      "@venus/lib/*": ["packages/lib/src/*"],

      "@venus/editor-primitive": ["packages/editor-primitive/src/index.ts"],
      "@venus/editor-primitive/*": ["packages/editor-primitive/src/*"],

      "@venus/engine": ["packages/engine/src/index.ts"],
      "react": ["apps/vector-editor-web/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["apps/vector-editor-web/node_modules/@types/react/jsx-runtime.d.ts"]
    }
  }
}
